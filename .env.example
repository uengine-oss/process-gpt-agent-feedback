# Supabase 설정 (필수)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# LLM 모델 설정 (선택, 미설정/빈값이면 기본값: gpt-4o)
LLM_MODEL=gpt-4o
# LiteLLM Proxy (권장, 프록시 우선)
LLM_PROXY_URL=http://localhost:4000
# LLM_PROXY_API_KEY가 없으면 OPENAI_API_KEY를 사용 (폴백)
LLM_PROXY_API_KEY=sk-...

# OpenAI API Key (선택, 프록시 키가 없을 때 폴백으로 사용)
OPENAI_API_KEY=your_openai_api_key

# 스킬 HTTP API 서버 (필수, SKILL 저장용) — process-gpt-deepagents가 제공하는 스킬 API
# (core/api/skills_router.py, server.py 기본 포트 8888). 별도 claude-skills 서비스가 아님.
SKILL_API_BASE_URL=http://localhost:8888

# Deep Agent가 참조할 스킬 디렉토리 (선택, 기본값: 레포 안 ./skills/)
# SKILLS_DIR=/path/to/skills

# 서버 포트 (선택, 기본값: 6789)
PORT=6789

# 디버그 모드 (선택)
DEBUG=false
